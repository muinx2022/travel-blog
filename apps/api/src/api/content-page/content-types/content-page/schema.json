{
  "kind": "collectionType",
  "collectionName": "content_pages",
  "info": {
    "singularName": "content-page",
    "pluralName": "content-pages",
    "displayName": "Content Page"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "navigationLabel": {
      "type": "string"
    },
    "showInHeader": {
      "type": "boolean",
      "default": false
    },
    "showInFooter": {
      "type": "boolean",
      "default": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
