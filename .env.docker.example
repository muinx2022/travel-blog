# Public API URL for Next.js apps
NEXT_PUBLIC_API_URL=http://127.0.0.1:1338

# Strapi server
HOST=0.0.0.0
PORT=1337

# Strapi required secrets
APP_KEYS=replace_me_1,replace_me_2,replace_me_3,replace_me_4
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
JWT_SECRET=replace_me

# Reuse existing PostgreSQL container from gikky-net stack
DATABASE_CLIENT=postgres
DATABASE_HOST=gikky-postgres
DATABASE_PORT=5432
DATABASE_NAME=travel_blog
DATABASE_USERNAME=replace_me
DATABASE_PASSWORD=replace_me
DATABASE_SSL=false
