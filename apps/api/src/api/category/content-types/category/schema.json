{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "posts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::post.post",
      "mappedBy": "categories"
    },
    "tours": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tour.tour",
      "mappedBy": "categories"
    },
    "hotels": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::hotel.hotel",
      "mappedBy": "categories"
    },
    "homestays": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::homestay.homestay",
      "mappedBy": "categories"
    },
    "restaurants": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::restaurant.restaurant",
      "mappedBy": "categories"
    },
    "souvenirShops": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::souvenir-shop.souvenir-shop",
      "mappedBy": "categories"
    },
    "travelGuides": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::travel-guide.travel-guide",
      "mappedBy": "categories"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category",
      "mappedBy": "parent"
    }
  }
}
